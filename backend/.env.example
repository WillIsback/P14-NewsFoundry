DATABASE_URL='postgresql://user:password@localhost:5432/newsfoundry'
SECRET_KEY='change-me'
APP_ENV='development'
SEED_DEFAULT_USER='true'
DEFAULT_USER_EMAIL='test@test.com'
DEFAULT_USER_PASSWORD='test'

# LLM Provider (vLLM via Tailscale en production, réseau local en dev)
# En prod Railway, LLM_BASE_URL doit pointer vers l'IP Tailscale du serveur vLLM.
# Vérifier la connectivité avec : GET /api/v1/health → subsystems.llm.status
LLM_BASE_URL='http://localhost:8000/v1'
LLM_API_KEY='EMPTY'
LLM_MODEL='default'
# Réduire en prod pour fail-fast sous le timeout Vercel (Hobby=10s, Pro=60s)
# Valeur recommandée production : 25 (laisse 5s de marge avec Vercel Pro 30s)
LLM_TIMEOUT_SECONDS='60'
# Borne le travail de l'agent (résilience sous GPU partagé / contention)
AGENT_MAX_TOKENS='800'
TOP_NEWS_CLUSTERS='5'

# WorldNewsAPI — clé API externe
WORLDNEWSAPI_KEY='your-key-here'

# Sentry (optionnel)
SENTRY_DSN=''
