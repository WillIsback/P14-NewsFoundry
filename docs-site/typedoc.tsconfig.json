{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "baseUrl": "../frontend",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "../frontend/src/**/*.ts",
    "../frontend/src/**/*.tsx"
  ],
  "exclude": [
    "../frontend/node_modules",
    "../frontend/src/**/__tests__/**",
    "../frontend/src/test/**",
    "../frontend/src/models/gen/**"
  ]
}
